{
    "version": 2,
    "builds": [
      {
        "src": "Backend/server.js",
        "use": "@vercel/node"
      },
      {
        "src": "netflix-frontend/dist/**/*",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "Backend/server.js"
      },
      {
        "src": "/(.*)",
        "dest": "netflix-frontend/dist/$1"
      }
    ]
  }
  